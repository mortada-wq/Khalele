# ─── Kheleel Environment Variables ─────────────────────────────────────
# Copy to .env.local for local dev. Set in Vercel/Amplify for production.

# AWS (required for Bedrock, DynamoDB, Polly, S3, Transcribe)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key

# Amazon Bedrock
BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0

# Amazon Polly (TTS)
POLLY_VOICE_ID=Zeina

# DynamoDB (conversations persist when table exists)
DYNAMODB_CONVERSATIONS_TABLE=khalele-conversations
# Optional:
# DYNAMODB_USERS_TABLE=khalele-users
# DYNAMODB_CORRECTIONS_TABLE=khalele-corrections
# DYNAMODB_TRAINING_TABLE=khalele-training-sessions

# S3 (for Transcribe output, training audio)
S3_TRAINING_BUCKET=khalele-training-data
S3_TRANSCRIPTION_BUCKET=khalele-training-data

# Resend (feedback emails in Data section)
RESEND_API_KEY=re_your_api_key
# RESEND_FROM=Kheleel <hello@kheleel.com>

# Admin (Phase 3: protect /admin/training)
# ADMIN_SECRET=your_admin_secret
