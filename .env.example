# ─── Kheleel Environment Variables ─────────────────────────────────────
# Copy to .env.local for local dev. Set in Vercel/Amplify for production.

# ─── AWS Core ─────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# ─── Bedrock ───────────────────────────────────────────────────────────
BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0
BEDROCK_REGION=us-east-1

# ─── Polly (TTS) ──────────────────────────────────────────────────────
POLLY_VOICE_ID=Zeina

# ─── S3 ──────────────────────────────────────────────────────────────
S3_TRAINING_BUCKET=khalele-training-data

# ─── DynamoDB ─────────────────────────────────────────────────────────
DYNAMODB_TRAINING_TABLE=khalele-training-sessions
DYNAMODB_CONVERSATIONS_TABLE=khalele-conversations
DYNAMODB_USERS_TABLE=khalele-users
DYNAMODB_CORRECTIONS_TABLE=khalele-corrections

# ─── NextAuth (Google OAuth) ───────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# ─── Admin ───────────────────────────────────────────────────────────
ADMIN_EMAIL=

# ─── Email (Resend) ──────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM=Kheleel <onboarding@resend.dev>

# ─── App ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_ENVIRONMENT=development
