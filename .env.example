# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key

# Amazon Bedrock
BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0

# Optional: Custom model after fine-tuning
# BEDROCK_MODEL_ID=your-custom-arabic-model-id

# Resend (for feedback emails in Data section)
RESEND_API_KEY=re_your_api_key
# Optional: Verified domain sender (default: onboarding@resend.dev)
# RESEND_FROM=Khalele <hello@khalele.com>
