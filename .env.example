# ─── Kheleel Environment Variables ─────────────────────────────────────
# Copy to .env.local for local dev. Set in Vercel/Amplify for production.

# ─── AWS Core ─────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# ─── SiliconFlow / DeepSeek (primary text LLM) ────────────────────────
SILICONFLOW_API_KEY=
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_MODEL=deepseek-ai/DeepSeek-V3.2

# ─── ElevenLabs (voice / TTS) ────────────────────────────────────────
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# ─── S3 ──────────────────────────────────────────────────────────────
S3_TRAINING_BUCKET=kheleel-training-data

# ─── DynamoDB ─────────────────────────────────────────────────────────
DYNAMODB_TRAINING_TABLE=kheleel-training-sessions
DYNAMODB_CONVERSATIONS_TABLE=kheleel-conversations
DYNAMODB_USERS_TABLE=kheleel-users
DYNAMODB_CORRECTIONS_TABLE=kheleel-corrections
DYNAMODB_INVITES_TABLE=kheleel-invites

# ─── NextAuth (Google OAuth) ───────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# ─── Admin ───────────────────────────────────────────────────────────
ADMIN_EMAIL=

# ─── Email (Resend) ──────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM=Kheleel <onboarding@resend.dev>

# ─── App ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_ENVIRONMENT=development
